<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="random_user_partner_action" model="ir.actions.act_window">
        <field name="name">Random User Partners</field>
        <field name="res_model">random.user.partner</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_random_user_partner_form" model="ir.ui.view">
        <field name="name">random.user.partner.form.inherit</field>
        <field name="model">random.user.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Créer utilisateur aléatoire" type="object" class="oe_highlight" name="create_random_user_partners"/>
                </header>
            </form>
        </field>
    </record>

    <record id="view_random_user_partner_tree" model="ir.ui.view">
        <field name="name">random.user.partner.tree.inherit</field>
        <field name="model">random.user.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
            </tree>
        </field>
    </record>

    <menuitem
        id="menu_random_user_partners"
        name="formIntegration"
    />
    <menuitem 
        id="menu_random_user_partners_views"
        name="RandomUserPartners"
        action="random_user_partner_action"
        parent="menu_random_user_partners"
    />
</odoo>

<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="view_hr_leave_allocation_form" model="ir.ui.view">
            <field name="name">hr.leave.allocation.form</field>
            <field name="model">hr.leave.allocation</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_form_manager"/>
            <field name="arch" type="xml">
                <field name="number_of_hours_display" position="before">
                    <field name="is_negative_allocation"/>
                </field>
            </field>
        </record>

        <record id="view_hr_leave_allocation_tree" model="ir.ui.view">
            <field name="name">hr.leave.allocation.tree</field>
            <field name="model">hr.leave.allocation</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_tree"/>
            <field name="arch" type="xml">
                <field name="duration_display" position="before">
                    <field name="is_negative_allocation"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
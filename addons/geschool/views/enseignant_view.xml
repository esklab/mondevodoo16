<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="ecole_enseignant_action" model="ir.actions.act_window">
        <field name="name">Gestion Ecole</field>
        <field name="res_model">ecole.enseignant</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>

    <record id="ecole_eleve_tree" model="ir.ui.view">
        <field name="name">Enseignant</field>
        <field name="model">ecole.enseignant</field>
        <field name="arch" type="xml">
            <tree string="Enseignant">
                <field name="name"/>
                <field name="prenom"/>
                <field name="cours_ids"/>
            </tree>
        </field>
    </record>

    <record id="ecole_eleve_form" model="ir.ui.view">
        <field name="name">ecole.enseignant.form</field>
        <field name="model">ecole.enseignant</field>
        <field name="arch" type="xml">
            <form string="Enseignant">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="prenom"/>
                            <field name="cours_ids" widget="many2many"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem 
        id="enseignant_menu" 
        name="Enseignant" 
        action="ecole_enseignant_action" 
        parent="ecole_menu" 
        sequence="100"
    />
    
</odoo>

<?xml version='1.0' encoding='utf-8'?>
<odoo>
    
        <record id="ecole_cours_action" model="ir.actions.act_window">
            <field name="name">Gestion Ecole</field>
            <field name="res_model">ecole.cours</field>
            <field name="view_mode">tree,form,kanban</field>
        </record>
    
        <record id="ecole_note_tree" model="ir.ui.view">
            <field name="name">Cours</field>
            <field name="model">ecole.cours</field>
            <field name="arch" type="xml">
                <tree string="cours">
                    <field name="name"/> 
                    <field name="enseignant_id"/>
                    <field name="classe_id"/>
                </tree>
            </field>
        </record>
    
        <record id="ecole_eleve_form" model="ir.ui.view">
            <field name="name">ecole.cours.form</field>
            <field name="model">ecole.cours</field>
            <field name="arch" type="xml">
                <form string="cours">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="enseignant_id"/>
                                <field name="classe_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    
        <menuitem 
            id="cours_menu" 
            name="Cours" 
            action="ecole_cours_action" 
            parent="ecole_menu"
        />
    
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View ecole.eleve View Tree -->
    <record id="view_ecole_eleve_tree" model="ir.ui.view">
        <field name="name">view.ecole.eleve.tree</field>
        <field name="model">ecole.eleve</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- View ecole.eleve form -->
    <record id="view_ecole_eleve_form" model="ir.ui.view">
        <field name="name">view.ecole.eleve.form</field>
        <field name="model">ecole.eleve</field>
        <field name="arch" type="xml">
            <form string="Ecole Eleve">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View ecole.eleve search -->
    <record id="view_ecole_eleve_search" model="ir.ui.view">
        <field name="name">view.ecole.eleve.search</field>
        <field name="model">ecole.eleve</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action ecole.eleve -->
    <record id="action_ecole_eleve" model="ir.actions.act_window">
        <field name="name">Ecole Eleve</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ecole.eleve</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Ecole Eleve.
            </p>
        </field>
    </record>

</odoo>
